# API environment for the Auto4You VPS.
# Copy to .env.api next to docker-compose.yml and fill in the CHANGEME values.
# All services referenced by hostname (postgres, redis, minio) live on the
# compose network — do not point these at localhost.

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
# Valid values: local | production | test (api/enums.py::Environment).
# Upstream's remote setup writes "production" for public deployments —
# "local" enables localhost-only WebRTC/TURN shortcuts we don't want here.
ENVIRONMENT=production
LOG_LEVEL=INFO

# Public base URL of the API. The VoiceLink provider derives BOTH the media
# websocket URL (wss://api.auto4you.in/api/v1/telephony/ws/...) and the call
# events webhook (https://api.auto4you.in/api/v1/telephony/voicelink/events/...)
# from this via api/utils/common.py::get_backend_endpoints. Must be https://
# and publicly reachable, or VoiceLink cannot stream call audio back to us.
BACKEND_API_ENDPOINT=https://api.auto4you.in

# Public base URL of the UI (used for embed/share links).
UI_APP_URL=https://app.auto4you.in

# ---------------------------------------------------------------------------
# Database / cache
# ---------------------------------------------------------------------------
# Async SQLAlchemy URL against the compose postgres service.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/postgres

# Redis with the password set in docker-compose.yml (--requirepass redissecret).
REDIS_URL=redis://:redissecret@redis:6379

# ---------------------------------------------------------------------------
# Storage (MinIO — recordings, transcripts, uploads)
# ---------------------------------------------------------------------------
# Keep AWS S3 off; we use the bundled MinIO.
ENABLE_AWS_S3=false

# Internal (container-to-container) MinIO endpoint, host:port without scheme.
MINIO_ENDPOINT=minio:9000
# Full URL browsers use to fetch recordings. Caddy proxies
# https://api.auto4you.in/voice-audio/* -> minio:9000, so the public endpoint
# is simply the API domain (the bucket name becomes the path prefix).
MINIO_PUBLIC_ENDPOINT=https://api.auto4you.in
# Must match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD in docker-compose.yml.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Bucket is auto-created by the api on first boot.
MINIO_BUCKET=voice-audio
# TLS between api and minio inside the compose network: off.
MINIO_SECURE=false

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
# Secret used to sign OSS login JWTs (HS256). Generate one:
#   openssl rand -hex 32
OSS_JWT_SECRET=CHANGEME-generate-with-openssl-rand-hex-32

# ---------------------------------------------------------------------------
# Process sizing (2-4GB box: keep at 1)
# ---------------------------------------------------------------------------
# Number of uvicorn worker processes spawned by the container entrypoint.
FASTAPI_WORKERS=1
# Number of arq background-task workers.
ARQ_WORKERS=1

# ---------------------------------------------------------------------------
# Telemetry
# ---------------------------------------------------------------------------
ENABLE_TELEMETRY=false

# ---------------------------------------------------------------------------
# TURN (optional — only needed for in-browser WebRTC test calls behind NAT;
# VoiceLink telephony calls do NOT use TURN). We run no coturn on this box.
# ---------------------------------------------------------------------------
# TURN_HOST=
# TURN_SECRET=
