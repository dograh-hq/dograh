# UI environment for the Auto4You VPS.
# Copy to .env.ui next to docker-compose.yml.
#
# NOTE: branding and the public backend URL (NEXT_PUBLIC_* vars) are BAKED
# into the image at build time by .github/workflows/saas-images.yml — setting
# them here has NO effect. To change them, edit the workflow build-args and
# rebuild the ui image.

# Server-side (SSR) backend URL over the internal Docker network.
BACKEND_URL=http://api:8000

# Upstream's OSS compose runs the ui with NODE_ENV=oss (selects the OSS auth
# provider in the Next.js server runtime). Keep as-is.
NODE_ENV=oss

# Disable PostHog analytics.
ENABLE_TELEMETRY=false
