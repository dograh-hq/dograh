BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_NODE_ENV=development

# --- White-label branding (see src/lib/brand.ts) ---
# Product name shown everywhere a client can see (default: "VoiceAI Platform")
NEXT_PUBLIC_BRAND_NAME=
# Optional logo image URL/path (e.g. /brand-logo.png placed in ui/public)
NEXT_PUBLIC_BRAND_LOGO=
# Optional tagline used in page metadata
NEXT_PUBLIC_BRAND_TAGLINE=
# Optional docs site base URL ("Learn more" links). Unset -> upstream docs.
NEXT_PUBLIC_BRAND_DOCS_URL=
# Optional legal links shown on the sign-in footer. Unset -> hidden.
NEXT_PUBLIC_BRAND_PRIVACY_URL=
NEXT_PUBLIC_BRAND_TERMS_URL=
# "true" to show upstream community links (GitHub star badge, Slack)
NEXT_PUBLIC_BRAND_COMMUNITY=
# "true" to force the client-safe UI (hide model/provider/API-key/engine
# settings) for ALL users regardless of org role
NEXT_PUBLIC_CLIENT_MODE=
